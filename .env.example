# =============================================================================
# .env.example — TUWAYKIFOOD
# Copiar a .env y completar los valores antes de arrancar.
#
# LOCAL:
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d --build
#
# SVR DE PRUEBA (AWS sin dominio):
#   git clone https://github.com/TreborOscorima/Sistema-para-Food.git ~/sist-food
#   cd ~/sist-food && cp .env.example .env && nano .env  (completar contraseñas)
#   TEST_IP=52.15.161.245 docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --build
#   Acceso: http://52.15.161.245:3003  (puerto 3003 abierto en Security Group AWS)
#
# Re-deploy en SVR:
#   git fetch origin docker-deploy-prod && git reset --hard origin/docker-deploy-prod
#   TEST_IP=52.15.161.245 docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --build
#
# PRODUCCIÓN (AWS + nginx en host):
#   bash scripts/deploy.sh    (en el servidor)
#   nginx usa ops/nginx/food-tuwayki.conf → food.tuwayki.com
# =============================================================================

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# DB totalmente independiente de Sistema-de-Ventas (distinto container, distinto puerto).
# Con Docker: DB_HOST lo sobreescribe el compose a "food_mysql" — no setear aquí.
# Desarrollo nativo (sin Docker): DB_HOST=localhost, DB_USER=root (o usuario local)
#DB_HOST=localhost
DB_PORT=3306
DB_NAME=food_db
# En Docker el compose crea usuario "food" en food_mysql — NO usar root.
# En desarrollo nativo podés usar root si tu MySQL local lo permite.
DB_USER=food
DB_PASSWORD=your_password_here

# Con Docker: root de food_mysql debe tener contraseña DISTINTA a DB_PASSWORD.
# No relacionado con el MySQL de Sistema-de-Ventas — son instancias separadas.
MYSQL_ROOT_PASSWORD=your_root_password_here_different

# ── Aplicación ────────────────────────────────────────────────────────────────
# ID de la empresa en el sistema TUWAYKIAPP (asignado por el Owner Admin)
FOOD_COMPANY_ID=1

# Entorno: dev | prod
# El compose ya inyecta ENV=prod — solo setear "dev" para desarrollo nativo sin Docker
ENV=dev

# Clave secreta para firmar JWT (OBLIGATORIA en producción — mínimo 32 chars aleatorios)
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=your_secret_key_here_min_32_chars

# IP pública del servidor de prueba (solo para SVR de prueba, no en producción)
# En producción el compose.prod sobreescribe con la URL del dominio
TEST_IP=52.15.161.245

# URL pública de la API (se sobreescribe en los compose overrides)
# LOCAL:   http://localhost:3003
# TEST:    http://<IP-EC2>:3003
# PROD:    https://food.tuwayki.com
PUBLIC_API_URL=http://localhost:3003
