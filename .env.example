# =============================================================================
# .env.example — TUWAYKIFOOD
# Copiar a .env antes de arrancar.
#
# LOCAL:
#   docker build -t tuwayki_food:latest .
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
#
# SVR DE PRUEBA (AWS sin dominio):
#   docker build -t tuwayki_food:latest .
#   TEST_IP=<IP-EC2> docker compose -f docker-compose.yml -f docker-compose.test.yml up -d
#   Acceso: http://<TEST_IP>:3003  (abrir puerto 3003 en Security Group)
#
# PRODUCCIÓN (AWS + nginx en host):
#   bash scripts/deploy.sh    (en el servidor)
#   nginx usa ops/nginx/food-tuwayki.conf → food.tuwayki.com
# =============================================================================

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# Con Docker: DB_HOST lo sobreescribe el compose a "food_mysql" — no setear aquí.
# Desarrollo nativo (sin Docker): DB_HOST=localhost
#DB_HOST=localhost
DB_PORT=3306
DB_NAME=food_db
DB_USER=food
DB_PASSWORD=your_password_here

# Con Docker: MySQL root debe tener contraseña DISTINTA a DB_PASSWORD.
MYSQL_ROOT_PASSWORD=your_root_password_here_different

# ── Aplicación ────────────────────────────────────────────────────────────────
# ID de la empresa en el sistema TUWAYKIAPP (asignado por el Owner Admin)
FOOD_COMPANY_ID=1

# Entorno: dev | prod
# El compose ya inyecta ENV=prod — solo setear "dev" para desarrollo nativo sin Docker
ENV=dev

# URL pública de la API (se sobreescribe en los compose overrides)
# LOCAL:   http://localhost:3003
# TEST:    http://<IP-EC2>:3003
# PROD:    https://food.tuwayki.com
PUBLIC_API_URL=http://localhost:3003
