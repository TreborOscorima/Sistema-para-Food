# Base de datos MySQL (food_db)
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=food_db

# ID de la empresa en el sistema TUWAYKIAPP (asignado por el Owner Admin)
FOOD_COMPANY_ID=1

# Entorno: dev | prod
ENV=dev

# Redis (requerido en prod para rate limiting)
REDIS_URL=

# Impresora de cocina (red ESC/POS)
PRINTER_KITCHEN_HOST=192.168.1.100
PRINTER_KITCHEN_PORT=9100
PRINTER_KITCHEN_TIMEOUT=10

# Impresora de caja (USB ESC/POS)
PRINTER_CASHIER_VENDOR_ID=0x04b8
PRINTER_CASHIER_PRODUCT_ID=0x0202

# URL pública de la API (Reflex)
PUBLIC_API_URL=http://localhost:3003
